# =============================================================================
# AndroMate RAG API - Environment Configuration
# =============================================================================
# This file contains environment variables for the RAG pipeline application.
# DO NOT commit sensitive information (API keys, passwords) to version control.
# Use .env.local for local overrides (add to .gitignore).

# ==================== API Configuration ====================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# ==================== Qdrant Vector Database ====================
QDRANT_HOST=localhost
QDRANT_PORT=6333
#QDRANT_API_KEY=your-api-key-here  # Uncomment for cloud Qdrant
QDRANT_COLLECTION_NAME=andromate_docs
QDRANT_VECTOR_SIZE=384

# ==================== Security Configuration ====================
API_KEY=your-secret-api-key

# ==================== Embedding Model ====================
# Model from HuggingFace that will be downloaded and cached
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# EMBEDDING_CACHE_DIR=/path/to/cache  # Optional: custom cache directory

# ==================== Text Processing ====================
CHUNK_MAX_SIZE=250
CHUNK_OVERLAP=60

# ==================== File Upload ====================
MAX_FILE_SIZE_MB=50

# ==================== Logging ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3

# ==================== LLM Configuration ====================
LLM_PROVIDER=openai
OPENAI_API_KEY=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
OLLAMA_MODEL=qwen3.5:4b
