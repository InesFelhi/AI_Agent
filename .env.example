# ====================================================================
# AndroMate AI Agent - Environment Configuration Template
# ====================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!
# ====================================================================

# ========== LLM PROVIDER SELECTION ==========
# Choose one LLM provider: openai, ollama, or openrouter
LLM_PROVIDER=openai

# ========== OPENAI CONFIGURATION ==========
# Required if LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-actual-api-key-here
OPENAI_MODEL=gpt-4-turbo
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=120

# ========== OLLAMA CONFIGURATION ==========
# Required if LLM_PROVIDER=ollama
# Make sure Ollama is running locally or accessible
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_TIMEOUT=120

# ========== OPENROUTER CONFIGURATION ==========
# Required if LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-your-openrouter-key
OPENROUTER_MODEL=openai/gpt-4
OPENROUTER_TIMEOUT=120

# ========== QDRANT VECTOR DATABASE ==========
# Connection to Qdrant server (local or remote)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_PREFER_GRPC=true          # Use gRPC for ~20% latency improvement
QDRANT_TIMEOUT=30                 # Connection timeout in seconds
QDRANT_COLLECTION_NAME=andromate_docs

# ========== API SECURITY & CONFIGURATION ==========
# IMPORTANT: Change API_KEY to a secure random value!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-secure-random-api-key-here

# API Server Configuration
API_HOST=0.0.0.0
CHAT_API_PORT=8000
RAG_API_PORT=8001
JOB_CHAT_API_PORT=8002

# ========== EMBEDDING MODELS ==========
# Dense embedding (semantic search)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Sparse embedding (keyword search)
SPARSE_EMBEDDING_MODEL=BM25

# ========== LOGGING CONFIGURATION ==========
LOG_LEVEL=INFO                    # Options: DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760            # 10MB
LOG_BACKUP_COUNT=5

# ========== PERFORMANCE TUNING ==========
# Timeouts
LLM_TIMEOUT_SECONDS=120           # LLM response timeout
MIDDLEWARE_TIMEOUT_SECONDS=120    # HTTP middleware timeout
RESPONSE_TIMEOUT=120              # Overall response timeout

# Cache Configuration
CACHE_TTL_SECONDS=3600            # 1 hour (3600 seconds)
CACHE_MAX_SIZE=1000               # Max number of cached responses

# Memory Cleanup
CLEANUP_INTERVAL_SECONDS=300      # Run cleanup every 5 minutes
CLEANUP_MAX_AGE_HOURS=1           # Remove entries older than 1 hour

# ========== MONITORING ==========
PROMETHEUS_PORT=9090
ENABLE_METRICS=true
METRICS_UPDATE_INTERVAL=10        # Update interval in seconds

# ========== CORS (Cross-Origin Resource Sharing) ==========
# Comma-separated list of allowed origins
# Leave empty to use defaults (localhost only)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ========== RATE LIMITING (Optional) ==========
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=100          # Requests per window
# RATE_LIMIT_WINDOW=60             # Time window in seconds

# ========== DEBUGGING & DEVELOPMENT ==========
DEBUG_MODE=false                  # Set to true for verbose debug logging
PROFILE_ENDPOINTS=false           # Profile endpoint performance
ENABLE_API_DOCS=true              # Enable Swagger UI at /docs

# ========== DATABASE PERSISTENCE ==========
# Path for storing processed data
DATA_DIR=data/
CHUNKS_DIR=data/chunks/
PROCESSED_DIR=data/processed/

# ========== ADDITIONAL CONFIGURATION ==========
# Project metadata
PROJECT_NAME=AndroMate AI Agent
PROJECT_VERSION=1.0.0
ENVIRONMENT=development           # Options: development, staging, production
